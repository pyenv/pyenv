From 7d11440b5de9a92ff7222b69da17f3ab2d2a5a70 Mon Sep 17 00:00:00 2001
From: Damien George <damien.p.george@gmail.com>
Date: Thu, 21 May 2020 11:27:09 +1000
Subject: [PATCH 4/4] py/py.mk: Use additional CFLAGS to compile string0.c.

Otherwise functions like memset might get optimised to call themselves (eg
with gcc 10).  And provide CFLAGS_BUILTIN so these options can be changed
by a port if needed.

Fixes issue #6053.
---
 py/py.mk | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/py/py.mk b/py/py.mk
index 3d8d849e2..549ff7826 100644
--- a/py/py.mk
+++ b/py/py.mk
@@ -348,6 +348,11 @@ $(HEADER_BUILD)/moduledefs.h: $(SRC_QSTR) $(QSTR_GLOBAL_DEPENDENCIES) | $(HEADER
 
 SRC_QSTR += $(HEADER_BUILD)/moduledefs.h
 
+# Standard C functions like memset need to be compiled with special flags so
+# the compiler does not optimise these functions in terms of themselves.
+CFLAGS_BUILTIN ?= -ffreestanding -fno-builtin -fno-lto
+$(BUILD)/lib/libc/string0.o: CFLAGS += $(CFLAGS_BUILTIN)
+
 # Force nlr code to always be compiled with space-saving optimisation so
 # that the function preludes are of a minimal and predictable form.
 $(PY_BUILD)/nlr%.o: CFLAGS += -Os
